{
  "manifest_version": 3,
  "name": "Job Medley Scout Assistant",
  "version": "1.0.0",
  "description": "ジョブメドレー スカウト送信アシスタント - プロフィール一括抽出・送信アシスト",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://job-medley.com/*",
    "https://*.job-medley.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://job-medley.com/*",
        "https://*.job-medley.com/*"
      ],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://job-medley.com/*",
        "https://*.job-medley.com/*"
      ],
      "js": ["src/content/main-world.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Scout Assistant"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
