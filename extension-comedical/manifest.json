{
  "manifest_version": 3,
  "name": "Comedical Scout Assistant",
  "version": "1.0.0",
  "description": "コメディカルドットコム (co-medical.com) スカウト送信アシスタント。型はめ固定で全てローカル完結。",
  "permissions": ["sidePanel", "storage", "activeTab"],
  "host_permissions": [
    "https://co-medical.com/*",
    "https://*.co-medical.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://co-medical.com/*",
        "https://*.co-medical.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Comedical Scout"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
