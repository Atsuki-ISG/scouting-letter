{
  "manifest_version": 3,
  "name": "Scout Assistant (WelMe + コメディカル)",
  "version": "1.0.0",
  "description": "WelMe (kaigojob.com) とコメディカルドットコム (co-medical.com) 両対応のスカウト送信アシスタント。型はめ固定で全てローカル完結。現在開いているサイトに応じて自動切替。",
  "permissions": ["sidePanel", "storage", "activeTab", "tabs"],
  "host_permissions": [
    "https://kaigojob.com/*",
    "https://*.kaigojob.com/*",
    "https://welme.jp/*",
    "https://*.welme.jp/*",
    "https://co-medical.com/*",
    "https://*.co-medical.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://kaigojob.com/*",
        "https://*.kaigojob.com/*",
        "https://welme.jp/*",
        "https://*.welme.jp/*",
        "https://co-medical.com/*",
        "https://*.co-medical.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Scout Assistant"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
