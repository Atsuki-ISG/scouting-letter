{
  "manifest_version": 3,
  "name": "Scout Sender - プロフィール抽出",
  "version": "1.0.0",
  "description": "ジョブメドレー スカウト対象者のプロフィールを一括抽出してCSVエクスポート",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://job-medley.com/*",
    "https://*.job-medley.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://job-medley.com/*",
        "https://*.job-medley.com/*"
      ],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Scout Sender - プロフィール抽出"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
